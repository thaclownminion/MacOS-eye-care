<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Descreen"
        x:Class="Descreen.MainWindow"
        x:DataType="local:MainViewModel"
        Title="Descreen"
        Width="420" Height="300"
        MinWidth="420" MinHeight="300"
        CanResize="False"
        Background="#1a1a1a"
        FontFamily="Segoe UI, SF Pro Display, Ubuntu, sans-serif">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a3a3a"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#111111" Padding="20,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="👁" FontSize="28" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Descreen"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding TimeLeftText}"
                               FontSize="12" Foreground="#aaaaaa"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="20,16" Spacing="10">

            <!-- Focus status -->
            <Border Background="#222222" CornerRadius="8" Padding="14,10">
                <TextBlock Text="{Binding FocusStatusText}"
                           Foreground="#aaaaaa" FontSize="13"/>
            </Border>

            <!-- Buttons row 1 -->
            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0"
                        Command="{Binding ToggleFocusModeCommand}"
                        Content="{Binding FocusButtonText}"
                        Background="#1e3a5f"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Command="{Binding TakeBreakNowCommand}"
                        Content="Take Break Now"
                        Background="#1e5f3a"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="5,0,0,0"/>
            </Grid>

            <!-- Buttons row 2 -->
            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0"
                        Command="{Binding OpenFeedbackCommand}"
                        Content="💬  Feedback"
                        Background="#3a2a4a"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Command="{Binding OpenGithubCommand}"
                        Content="🐙  GitHub"
                        Background="#2a2a3a"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="5,0,0,0"/>
            </Grid>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#111111" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="© Kai Rozema"
                           Foreground="#555555" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Command="{Binding HideWindowCommand}"
                        Content="—  Hide"
                        Background="#2a2a2a"
                        FontSize="12"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="2"
                        Command="{Binding OpenSettingsCommand}"
                        Content="⚙  Settings"
                        Background="#2a2a2a"
                        FontSize="12"/>
            </Grid>
        </Border>

    </Grid>
</Window>
